@namespace Beauo.Components

@inject NavigationManager NavigationManager

@if (AsButton)
{
    <Button Text="@Text" IconLeft="@(!IconRight)" Icon="@Icon" OnClick="() => NavigationManager.NavigateTo(Href)" />
}
else
{
    <a href="@Href">
        <Row Align="@AlignItemsClass.Center" Gap="GapClass.Tiny" Reverse="@IconRight">
            @if (Icon is not null)
            {
                @Icon
            }
            <Text Size="TextSizeClass.Inherit" >
                @Text
            </Text>
        </Row>
    </a>
}

@code {
    [Parameter, EditorRequired] public string Href { get; set; }
    [Parameter, EditorRequired] public string Text { get; set; }
    [Parameter] public bool IconRight { get; set; } = false;
    [Parameter] public bool AsButton { get; set; }

    [Parameter] public RenderFragment? Icon { get; set; }
}