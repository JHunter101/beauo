@namespace Beauo.Components.Settings

@typeparam TValue where TValue : notnull

<Field>
	<ChildContent>
		<select id="@_id"
				@bind="@Value"
				@bind:after="@(() => ValueChanged.InvokeAsync(Value))"
				disabled="@IsDisabled">
			@foreach (var option in Options)
			{
				<option value="@option">
					@if (ChildContent != null)
					{
						@ChildContent(option)
					}
					else
					{
						@option.ToString()
					}
				</option>
			}
		</select>
	</ChildContent>

	<Label>
		@Label
	</Label>
</Field>

@code {
	[Parameter, EditorRequired] public TValue Value { get; set; }
	[Parameter, EditorRequired] public EventCallback<TValue> ValueChanged { get; set; }

	[Parameter, EditorRequired] public string Label { get; set; }
	[Parameter, EditorRequired] public IEnumerable<TValue> Options { get; set; }

	[Parameter] public bool IsDisabled { get; set; }

	[Parameter] public RenderFragment<TValue>? ChildContent { get; set; }

	private readonly string _id = Guid.NewGuid().ToString("N");
}