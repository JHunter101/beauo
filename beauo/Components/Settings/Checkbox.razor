@namespace Beauo.Components.Settings

<Field Label="@ChildContent" InputFirst>
		<input type="checkbox"
			   @bind="@Value"
			   @bind:after="@(() => ValueChanged.InvokeAsync(Value))"
			   disabled="@IsDisabled" />
</Field>


@code {
	[Parameter, EditorRequired]	public bool Value { get; set; }
	[Parameter, EditorRequired]	public EventCallback<bool> ValueChanged { get; set; }

	[Parameter] public bool IsDisabled { get; set; }

	[Parameter] public RenderFragment? ChildContent { get; set; }
}