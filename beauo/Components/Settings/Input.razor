@namespace Beauo.Components.Settings

@using Beauo.Components.Internal

<Field Label="@ChildContent">
	<input type="text"
		   id="@_id"
		   @bind="@Value"
		   @bind:after="@(() => ValueChanged.InvokeAsync(Value))"
		disabled="@IsDisabled" />
</Field>

@code {
	[Parameter, EditorRequired] public string Value { get; set; }
	[Parameter, EditorRequired] public EventCallback<string> ValueChanged { get; set; }

	[Parameter] public bool IsDisabled { get; set; }

	[Parameter] public RenderFragment? ChildContent { get; set; }
	
	private string _id = Guid.NewGuid().ToString("N");
}